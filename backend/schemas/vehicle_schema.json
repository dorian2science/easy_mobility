{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://club-mobilite-pierrefontaine.fr/schemas/vehicle_schema.json",
  "title": "Vehicle",
  "description": "Fiche identité d'un véhicule du Club de Mobilité Pierrefontaine",
  "type": "object",
  "required": ["registration", "vehicle_info", "owner", "current_state", "pricing_params", "availability"],
  "properties": {
    "registration": {
      "type": "object",
      "required": ["plate", "vin", "ct_expiry", "insurance_expiry"],
      "properties": {
        "plate": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]{3}-[A-Z]{2}$" },
        "vin": { "type": "string", "minLength": 17, "maxLength": 17 },
        "ct_expiry": { "type": "string", "format": "date" },
        "insurance_expiry": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "vehicle_info": {
      "type": "object",
      "required": ["make", "model", "year", "category", "fuel_type"],
      "properties": {
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "integer", "minimum": 2000, "maximum": 2030 },
        "category": { "type": "string", "enum": ["A", "B", "C", "D", "E"] },
        "fuel_type": { "type": "string", "enum": ["essence", "diesel", "electrique", "hybride", "hybride_rechargeable"] },
        "consumption_real": {
          "type": "number",
          "minimum": 0,
          "description": "L/100km for thermal, kWh/100km for electric; 0 for full electric"
        },
        "seats": { "type": "integer", "minimum": 2, "maximum": 9 },
        "transmission": { "type": "string", "enum": ["manuelle", "automatique"] }
      },
      "additionalProperties": false
    },
    "owner": {
      "type": "object",
      "required": ["member_id", "name", "nb_reviews", "rating"],
      "properties": {
        "member_id": { "type": "string" },
        "name": { "type": "string" },
        "nb_reviews": { "type": "integer", "minimum": 0 },
        "rating": { "type": "number", "minimum": 1.0, "maximum": 5.0 }
      },
      "additionalProperties": false
    },
    "current_state": {
      "type": "object",
      "required": ["odometer_km", "condition", "comfort", "fuel_level_pct"],
      "properties": {
        "odometer_km": { "type": "integer", "minimum": 0 },
        "condition": { "type": "string", "enum": ["excellent", "bon", "correct", "acceptable"] },
        "comfort": { "type": "string", "enum": ["basique", "standard", "confort", "premium"] },
        "fuel_level_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "known_defects": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "maintenance_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "type", "km", "description"],
            "properties": {
              "date": { "type": "string", "format": "date" },
              "type": { "type": "string" },
              "km": { "type": "integer" },
              "description": { "type": "string" }
            }
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "pricing_params": {
      "type": "object",
      "required": ["age_years", "annual_km_owner"],
      "properties": {
        "age_years": { "type": "number", "minimum": 0 },
        "annual_km_owner": { "type": "integer", "minimum": 0 },
        "include_fuel_default": { "type": "boolean", "default": false },
        "min_booking_hours": { "type": "number", "minimum": 1, "default": 4 },
        "max_booking_days": { "type": "number", "minimum": 1, "default": 7 },
        "owner_margin_override": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.20,
          "description": "Override default 5% margin (0.05); max 20%"
        }
      },
      "additionalProperties": false
    },
    "photo_url": {
      "type": "string",
      "description": "URL of vehicle photo (optional)",
      "format": "uri"
    },
    "availability": {
      "type": "object",
      "required": ["available"],
      "properties": {
        "available": { "type": "boolean" },
        "unavailable_periods": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "reason"],
            "properties": {
              "from": { "type": "string", "format": "date" },
              "to": { "type": "string", "format": "date" },
              "reason": { "type": "string" }
            }
          },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
